# Production PostgreSQL connection. Leave empty in local demo mode.
DATABASE_URL=

# A random 32+ character secret used to sign the HTTP-only session cookie.
SESSION_SECRET=replace-with-a-long-random-secret

# Local demo mode creates sample users and polls and exposes /demo/login.
DINGTALK_MOCK_ENABLED=true

# DingTalk internal app settings used when mock mode is disabled.
DINGTALK_CORP_ID=
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_APP_BASE_URL=https://vote.example.com

# Protects scheduler endpoints called by cron.
MAINTENANCE_SECRET=replace-with-a-long-random-secret

# Daily pg_dump destination and retention.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=365
