# Production PostgreSQL connection. Leave empty in local demo mode.
DATABASE_URL=

# A random 32+ character secret used to sign the HTTP-only session cookie.
SESSION_SECRET=replace-with-a-long-random-secret
# Keep true for HTTPS. Set false only for an explicitly allowed private HTTP target.
SESSION_COOKIE_SECURE=true

# Local demo mode creates sample users and polls and exposes /demo/login.
DINGTALK_MOCK_ENABLED=true
# Never enable this on a real production deployment. It only allows a private
# staging/demo host to use an optimized production build with mock identities.
ALLOW_INSECURE_PRODUCTION_MOCK=false

# DingTalk internal app settings used when mock mode is disabled.
DINGTALK_CORP_ID=
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_APP_BASE_URL=https://vote.example.com
# Only for an explicitly approved private-network HTTP production target.
DINGTALK_APP_ALLOW_INSECURE_BASE_URL=false
# Exact browser OAuth callback URL registered in the DingTalk application.
DINGTALK_WEB_REDIRECT_URI=https://vote.example.com/api/auth/dingtalk/web/callback

# When DATABASE_URL is empty and mock mode is disabled, local development uses
# an in-memory database and provisions this real DingTalk account as an HR admin.
DINGTALK_DEV_ADMIN_USER_ID=
DINGTALK_DEV_ADMIN_NAME=
DINGTALK_DEV_ADMIN_DEPARTMENT=

# Protects scheduler endpoints called by cron.
MAINTENANCE_SECRET=replace-with-a-long-random-secret

# Daily pg_dump destination and retention.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=365

# Internal OpenAI-compatible audio transcription service. If required, the API
# key stays server-side and is never exposed to the browser.
INTERNAL_LLM_TRANSCRIPTIONS_URL=https://llm.zgci.org/hub/v1/audio/transcriptions
INTERNAL_LLM_TRANSCRIBE_MODEL=qwen-asr
INTERNAL_LLM_API_KEY=
OPENROUTER_CHAT_COMPLETIONS_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_AUDIO_TRANSCRIBE_MODEL=google/gemini-2.5-flash
